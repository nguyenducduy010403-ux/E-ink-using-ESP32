/*
  ESP32-S3 N16R8 + E-Paper GDEH0213Z98: displays a 2-color (Black/Red on White) image of Zoro
  The image has been rotated 90 degrees to fit exactly 122x250 (rotation 0), Floyd-Steinberg
  dithered. The image is only drawn once at boot (the panel does not support partial refresh).

  PIN MAPPING (ESP32-S3 N16R8):
  Pins were chosen within the GPIO1-GPIO14 range to avoid:
   - Strapping pins (0, 3, 45, 46)
   - The Octal SPI Flash/PSRAM pins used on the N16R8 board (GPIO26-37)
   - The native USB pins (19, 20), in case USB is needed

  TP14 (SCL/SCK)   -> GPIO12   (Critical - clock signal, keep the trace as short as possible)
  TP15 (SDA/MOSI)  -> GPIO11   (Critical - data signal, keep the trace as short as possible)
  TP13 (CSB)       -> GPIO10   (Should be short, but less strict than SCL/SDA)
  TP12 (DC)        -> GPIO9    (Not critical - slow-changing signal)
  TP11 (RST_N)     -> GPIO8    (Not critical - only toggles at boot)
  TP6  (BUSY_N)    -> GPIO7    (Not critical - just a 0/1 status read, input)
  TP5  (BS)        -> GND      (hard-wired, fixed logic level)

  Power:
  Pin C1 (VDD)     -> 3.3V     (should have a decoupling capacitor nearby)
  D6 pin 8 (VDDIO) -> 3.3V     (should have a decoupling capacitor nearby)
  GND1 (VSS)       -> GND
*/

#include <GxEPD2_3C.h>

#define PIN_CS    10
#define PIN_DC    9
#define PIN_RST   8
#define PIN_BUSY  7
#define PIN_SCK   12
#define PIN_MOSI  11

GxEPD2_3C<GxEPD2_213_Z98c, GxEPD2_213_Z98c::HEIGHT> display(
  GxEPD2_213_Z98c(PIN_CS, PIN_DC, PIN_RST, PIN_BUSY));

#define IMG_WIDTH  122
#define IMG_HEIGHT 250

