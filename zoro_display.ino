  SPI.begin(PIN_SCK, -1, PIN_MOSI, PIN_CS);
  display.init(115200, true, 50, false);
  display.setRotation(0);  // image already fits portrait orientation, 122x250

  display.firstPage();
  do {
    display.fillScreen(GxEPD_WHITE);
    display.drawBitmap(0, 0, image_black, IMG_WIDTH, IMG_HEIGHT, GxEPD_BLACK);
    display.drawBitmap(0, 0, image_red,   IMG_WIDTH, IMG_HEIGHT, GxEPD_RED);
  } while (display.nextPage());

  Serial.println("Zoro image drawn successfully.");
  display.hibernate();
}

void loop() {
  // Static image, nothing to do in loop()
}
